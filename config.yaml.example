bus:
  http_port: 3000
  db_path: ./data/agentbus.db
  log_level: info

adapters:
  telegram:
    token: ${TELEGRAM_BOT_TOKEN}
    poll_timeout: 30
  bluebubbles:
    server_url: http://localhost:1234
    webhook_port: 3002
  claude-code:
    poll_interval_ms: 1000

contacts:
  alice:
    id: alice
    displayName: Alice
    platforms:
      telegram:
        userId: 123456789
        username: alice_example
      bluebubbles:
        handle: "+15551234567"

topics:
  - general
  - reminders
  - code
  - personal

memory:
  summarizer_interval_ms: 60000
  session_idle_threshold_ms: 1800000
  context_window_hours: 48
  claude_api_model: claude-opus-4-6

pipeline: {}
